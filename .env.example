# Anthropic API key for Claude.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Claude model to use. Default: claude-sonnet-4-6
CLAUDE_MODEL=claude-sonnet-4-6

# Command to launch the MCP server subprocess.
MCP_SERVER_CMD=/app/homelab-mcp-server

# Bootstrap password for the admin account (first run only).
ADMIN_PASSWORD=your-admin-password-here

# Secret for signing session tokens.
SESSION_SECRET=your-session-secret-here

# Directory for SQLite DB and state. Default: /data
DATA_DIR=/data

# Port this server listens on. Default: 8080
PORT=8080

# Log level: debug, info, warn, error. Default: info
LOG_LEVEL=info

# Gateway URLs and API keys (same vars passed to MCP subprocess).
# These are optional — admin endpoints use them for health checks and server stop.
# NOMAD_GATEWAY_URL=http://nomad-gateway.example.com:8080
# NOMAD_GATEWAY_KEY=your-nomad-gateway-key
# ADGUARD_GATEWAY_URL=http://adguard-gateway.example.com:8080
# ADGUARD_GATEWAY_KEY=your-adguard-gateway-key
# CF_GATEWAY_URL=http://cf-gateway.example.com:8080
# CF_GATEWAY_KEY=your-cf-gateway-key
# MINECRAFT_GATEWAY_URL=http://minecraft-gateway.example.com:8080
# MINECRAFT_GATEWAY_KEY=your-minecraft-gateway-key
# CURSEFORGE_GATEWAY_URL=http://curseforge-gateway.example.com:8080
# CURSEFORGE_GATEWAY_KEY=your-curseforge-gateway-key
# VAULT_GATEWAY_URL=http://vault-gateway.example.com:8080
# VAULT_GATEWAY_KEY=your-vault-gateway-key
